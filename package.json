{
  "name": "guitar-sound-advisor",
  "version": "1.0.0",
  "description": "CLI chatbot that recommends guitar/amp/pedal settings from your own inventory",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "tone": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "web": "tsx src/index.ts web"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0",
    "openai": "^4.67.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
